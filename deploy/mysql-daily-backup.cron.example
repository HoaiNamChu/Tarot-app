# Replace database/user/password/path before enabling.
# Recommended: create /var/backups/tarot and keep it readable only by root.
#
# 30 2 * * * mysqldump --single-transaction --routines --triggers -u tarot_user -p'CHANGE_STRONG_PASSWORD' tarot_database | gzip > /var/backups/tarot/tarot_$(date +\%F).sql.gz && find /var/backups/tarot -type f -name 'tarot_*.sql.gz' -mtime +14 -delete
