[program:tarot-queue]
process_name=%(program_name)s_%(process_num)02d
command=php /var/www/tarot/backend/artisan queue:work --tries=3 --timeout=90
autostart=true
autorestart=true
stopasgroup=true
killasgroup=true
user=www-data
numprocs=1
redirect_stderr=true
stdout_logfile=/var/www/tarot/backend/storage/logs/queue-worker.log
stopwaitsecs=120

