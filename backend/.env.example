APP_NAME="Luna Arcana"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tarot_database
DB_USERNAME=tarot_user
DB_PASSWORD=change-me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# For larger traffic, install Redis and switch:
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis
# SESSION_DRIVER=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_ENCRYPTION=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=hello@example.com
MAIL_PASSWORD=change-me
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

DAILY_LIMIT_GUEST=3
DAILY_LIMIT_USER=5

ADMIN_EMAIL=admin@example.com
FRONTEND_URL=https://app.example.com
ADMIN_FRONTEND_URL=https://admin.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
SANCTUM_EXPIRATION=10080
AUTH_REGISTER_THROTTLE=30,1
AUTH_LOGIN_THROTTLE=60,1
AUTH_PASSWORD_THROTTLE=20,1
AUTH_SESSION_THROTTLE=240,1
BANK_NAME=Vietcombank
BANK_BIN=970436
BANK_ACCOUNT_NUMBER=1234567890
BANK_ACCOUNT_NAME=LUNA ARCANA
BANK_TRANSFER_PREFIX=LUNA

VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://pay.vnpay.vn/vpcpay.html
VNPAY_RETURN_URL=https://api.example.com/api/payment/vnpay/return
VNPAY_IPN_URL=https://api.example.com/api/payment/vnpay/ipn

MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=https://api.example.com/api/payment/momo/return
MOMO_IPN_URL=https://api.example.com/api/payment/momo/ipn
MOMO_LANG=vi

# Frontend build-time variable examples:
# VITE_API_URL=https://api.example.com
