# Example environment variables for user-app (Vite)
# Copy this file to `.env.local` or `.env` and update values for your environment.

# Base URL for API requests used by `src/services/api.js`.
# Must start with VITE_ to be exposed to the client by Vite.
VITE_API_URL=https://api.example.com
VITE_BANK_NAME=Vietcombank
VITE_BANK_BIN=970436
VITE_BANK_ACCOUNT_NUMBER=0000000000
VITE_BANK_ACCOUNT_NAME=LUNA ARCANA
VITE_BANK_TRANSFER_PREFIX=LUNA
